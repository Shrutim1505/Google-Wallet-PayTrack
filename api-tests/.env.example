# =============================================================================
#  Google-Wallet-PayTrack API Test Framework — environment template
#  Copy to `.env` and adjust values per developer / CI agent.
# =============================================================================

# ---------- Target environment selector ----------
# Maps to a YAML file in `config/` (config.<TEST_ENV>.yaml).
TEST_ENV=dev

# ---------- API endpoint overrides ----------
API_BASE_URL=http://localhost:5000
API_PREFIX=/api
API_TIMEOUT_SECONDS=30
API_VERIFY_SSL=false

# ---------- Auth secrets (used by JWT helper for negative-path tests) ----------
# Must match the backend `JWT_SECRET` for signature-validation tests.
JWT_SECRET=change-me-to-at-least-32-random-characters-please
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# ---------- Pre-provisioned test users (optional) ----------
# When set, the framework reuses these instead of registering fresh ones —
# useful for RBAC suites where seed users have specific roles.
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=
VIEWER_USER_EMAIL=
VIEWER_USER_PASSWORD=

# ---------- Database (for DB-validation suite) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paytrack_test
DB_USER=paytrack
DB_PASSWORD=paytrack
DB_POOL_SIZE=5

# ---------- Reporting ----------
ALLURE_RESULTS_DIR=reports/allure-results
HTML_REPORT_PATH=reports/html/report.html
LOG_LEVEL=INFO

# ---------- Parallel / retry tuning ----------
PARALLEL_WORKERS=auto
RERUN_FAILED=1
RERUN_DELAY_SECONDS=2
