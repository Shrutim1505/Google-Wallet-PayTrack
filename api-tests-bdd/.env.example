# =============================================================================
#  Behave BDD — environment template
#  Copy to `.env` and adjust per host / CI agent.
# =============================================================================

TEST_ENV=dev

# Reuses the same backend as api-tests
API_BASE_URL=http://localhost:5000
API_PREFIX=/api
API_TIMEOUT_SECONDS=30
API_VERIFY_SSL=false

JWT_SECRET=change-me-to-at-least-32-random-characters-please

# DB used by post-step validation
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paytrack_test
DB_USER=paytrack
DB_PASSWORD=paytrack

LOG_LEVEL=INFO
