{
  "name": "paytrack-backend",
  "version": "1.0.0",
  "description": "Smart receipt management system backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "tsx src/benchmarks/db-benchmark.ts",
    "benchmark:algorithms": "tsx src/benchmarks/algorithms-benchmark.ts",
    "migrate": "node-pg-migrate --migrations-dir migrations --envPath .env.local",
    "migrate:up": "npm run migrate -- up",
    "migrate:down": "npm run migrate -- down",
    "migrate:create": "npm run migrate -- create",
    "db:setup": "createdb paytrack 2>/dev/null; createdb paytrack_test 2>/dev/null; echo 'Databases ready'",
    "docker:dev": "docker-compose -f ../docker-compose.dev.yml up -d"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.6",
    "@sentry/node": "^10.56.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.14",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.43.0",
    "supertest": "^7.2.2",
    "tsx": "^3.12.7",
    "typescript": "^5.1.3",
    "vitest": "^4.1.5"
  }
}
