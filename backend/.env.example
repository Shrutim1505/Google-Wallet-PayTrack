# Server Configuration
PORT=5000
NODE_ENV=development

# SQLite Database
SQLITE_FILENAME=paytrack.sqlite

# JWT Configuration
JWT_SECRET=your-ultra-secure-secret-key-min-32-chars-change-in-production
JWT_EXPIRY=15m
REFRESH_EXPIRY_DAYS=7

# Security
BCRYPT_ROUNDS=12

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Log Level
LOG_LEVEL=info

# Google Cloud Vision OCR (leave blank for mock OCR)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_FILE=

# Google Wallet Integration (leave blank for mock mode)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CALLBACK_URL=http://localhost:5000/api/wallet/webhook

# OpenAI API Key (for future AI features)
OPENAI_API_KEY=
