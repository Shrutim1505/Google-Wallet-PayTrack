# Server Configuration
PORT=5000
NODE_ENV=development

# SQLite Database (file path relative to backend root)
SQLITE_FILENAME=paytrack.sqlite

# JWT Configuration
JWT_SECRET=your-ultra-secure-secret-key-min-32-chars-change-in-production
JWT_EXPIRY=7d

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Log Level (debug | info | warn | error)
LOG_LEVEL=info
# LOG_PRETTY=true  # Uncomment for pretty-printed dev logs (requires pino-pretty)
