# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# You need to install PostgreSQL locally or use a service like ElephantSQL
# Local: postgresql://postgres:password@localhost:5432/paytrack_db
# Cloud: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/paytrack_db

# JWT Configuration
JWT_SECRET=your-ultra-secure-secret-key-min-32-chars-change-in-production
JWT_EXPIRY=7d

# Frontend Configuration (matches your Vite frontend)
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Optional: Google Cloud (SKIP FOR NOW - we'll use mock OCR)
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_KEY_FILE=/path/to/service-account-key.json

# Optional: Redis (SKIP FOR NOW)
# REDIS_URL=redis://localhost:6379

# Optional: Email (SKIP FOR NOW)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Log Level
LOG_LEVEL=info