# ─── Server ───
NODE_ENV=development
PORT=5000

# ─── Security (REQUIRED in production) ───
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-at-least-32-random-characters-please
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ───
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── PostgreSQL ───
DATABASE_URL=postgresql://paytrack:paytrack@localhost:5432/paytrack
DB_POOL_MAX=20

# ─── Redis (required in production, optional in dev) ───
REDIS_URL=redis://localhost:6379

# ─── Google Cloud Vision OCR (optional) ───
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_KEY_FILE=

# ─── Google Wallet (optional) ───
GOOGLE_WALLET_ISSUER_ID=

# ─── File uploads ───
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_STORAGE=local
# S3_BUCKET=
# S3_REGION=

# ─── Observability ───
SENTRY_DSN=
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Rate limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Password reset ───
PASSWORD_RESET_TTL_MINUTES=30

# ─── Currency API ───
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
